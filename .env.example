# Server-side API rewrite target (used by proxy.ts)
API_URL=http://localhost:8080

# Client API base URL — leave empty to use same-origin /api/v1 via proxy
NEXT_PUBLIC_API_URL=

# WebSocket base URL — optional; derives from NEXT_PUBLIC_API_URL (http→ws) when that is set.
# When NEXT_PUBLIC_API_URL is empty (REST via proxy), point at the backend WS origin:
NEXT_PUBLIC_WS_URL=ws://localhost:8080

NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com